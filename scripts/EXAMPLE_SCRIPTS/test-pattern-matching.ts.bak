/**
 * Test Pattern Matching Library
 * 
 * Simple test to verify pattern matching functions work correctly.
 */

// ============================================================================
// SIMPLE PATTERN MATCHING FUNCTIONS (INLINE FOR TESTING)
// ============================================================================

function matchPattern(text: string, pattern: string, options: { exact?: boolean; caseSensitive?: boolean } = {}): { match: boolean; confidence: number } {
  const { exact = false, caseSensitive = false } = options;
  
  let searchText = text;
  let searchPattern = pattern;
  
  if (!caseSensitive) {
    searchText = text.toLowerCase();
    searchPattern = pattern.toLowerCase();
  }
  
  if (exact) {
    return {
      match: searchText === searchPattern,
      confidence: searchText === searchPattern ? 1.0 : 0.0
    };
  }
  
  // Convert wildcard pattern to regex
  const regexPattern = searchPattern.replace(/\*/g, '.*');
  const regex = new RegExp(`^${regexPattern}$`);
  
  if (regex.test(searchText)) {
    // Calculate confidence based on how well it matches
    const wildcardCount = (pattern.match(/\*/g) || []).length;
    const exactParts = pattern.split('*').filter(part => part.length > 0);
    
    let score = 0;
    for (const part of exactParts) {
      if (searchText.includes(part)) {
        score += part.length;
      }
    }
    
    const confidence = Math.min(score / text.length, 1);
    return { match: true, confidence };
  }
  
  return { match: false, confidence: 0.0 };
}

function extractCollection(itemName: string): string {
  const parts = itemName.split('/');
  return parts[0] || 'Default';
}

// ============================================================================
// TEST FUNCTIONS
// ============================================================================

function testPatternMatching() {
  console.log('🧪 Testing Pattern Matching Functions...');
  
  // Test 1: Basic wildcard matching
  console.log('\n📋 Test 1: Basic wildcard matching');
  const test1 = matchPattern('website V2/typography/heading', 'website V2/*');
  console.log(`'website V2/typography/heading' matches 'website V2/*': ${test1.match} (confidence: ${test1.confidence})`);
  
  // Test 2: Exact matching
  console.log('\n📋 Test 2: Exact matching');
  const test2 = matchPattern('exact match', 'exact match', { exact: true });
  console.log(`'exact match' exactly matches 'exact match': ${test2.match} (confidence: ${test2.confidence})`);
  
  // Test 3: Case insensitive matching
  console.log('\n📋 Test 3: Case insensitive matching');
  const test3 = matchPattern('Website V2/Typography', 'website v2/*', { caseSensitive: false });
  console.log(`'Website V2/Typography' matches 'website v2/*' (case insensitive): ${test3.match} (confidence: ${test3.confidence})`);
  
  // Test 4: Collection extraction
  console.log('\n📋 Test 4: Collection extraction');
  const collection1 = extractCollection('website V2/typography/heading');
  const collection2 = extractCollection('brand/colors/primary');
  console.log(`Collection from 'website V2/typography/heading': ${collection1}`);
  console.log(`Collection from 'brand/colors/primary': ${collection2}`);
  
  // Test 5: No match
  console.log('\n📋 Test 5: No match');
  const test5 = matchPattern('completely different', 'website V2/*');
  console.log(`'completely different' matches 'website V2/*': ${test5.match} (confidence: ${test5.confidence})`);
  
  console.log('\n✅ Pattern matching tests completed!');
  figma.notify('✅ Pattern matching tests completed - check console for results');
}

// ============================================================================
// SCRIPT EXECUTION
// ============================================================================

// Run the test
testPatternMatching();
