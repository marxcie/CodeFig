/**
 * Test Basic Functions
 * 
 * Ultra-simple test to verify basic functionality works.
 */

function testBasicFunctions() {
  console.log('🧪 Testing basic functions...');
  
  // Test 1: Basic string operations
  const testString = 'website V2/typography/heading';
  const parts = testString.split('/');
  console.log(`Split '${testString}' into parts:`, parts);
  
  // Test 2: Basic pattern matching (simple version)
  const pattern = 'website V2/*';
  const regex = new RegExp('^' + pattern.replace(/\*/g, '.*') + '$');
  const matches = regex.test(testString);
  console.log(`'${testString}' matches pattern '${pattern}': ${matches}`);
  
  // Test 3: Basic collection extraction
  const collection = parts[0] || 'Default';
  console.log(`Collection from '${testString}': ${collection}`);
  
  // Test 4: Basic variable counting
  const selection = figma.currentPage.selection;
  console.log(`Current selection has ${selection.length} nodes`);
  
  console.log('✅ Basic functions test completed!');
  figma.notify('✅ Basic functions test completed - check console');
}

// Run the test
testBasicFunctions();
